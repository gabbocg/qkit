Binding: create_project
Type: project
Title: qkit Beamer Presentation
OpenFiles: index.qmd
Subtitle: Create a new Beamer presentation from the qkit template.

Parameter: title
Widget: TextInput
Label: Presentation title
Default: Untitled Presentation
Position: left

Parameter: type
Widget: TextInput
Label: (do not edit) format type
Default: beamer
Position: left
